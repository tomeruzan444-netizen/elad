---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import BlogList from '../components/BlogList.astro';
import { site, bySlug, industries, label, serviceGroups } from '../data/site';
import { buildJsonLd } from '../lib/content';

const home = bySlug('index')!;
const heroImg = '/assets/img/-----------min-1.webp';

const services = [
  { slug: 'פיתוח-עסקי', title: 'ייעוץ ופיתוח עסקי', desc: 'אסטרטגיה, מיקוד ותהליכי צמיחה שמותאמים לעסק שלכם.', icon: '📈' },
  { slug: 'בניית-אסטרטגיה-שיווקית', title: 'אסטרטגיה שיווקית', desc: 'בניית אסטרטגיית שיווק מנצחת שמביאה לקוחות חדשים.', icon: '🎯' },
  { slug: 'שיווק-ממומן', title: 'שיווק ממומן', desc: 'קמפיינים ממוקדים שמייצרים לידים איכותיים כאן ועכשיו.', icon: '🚀' },
  { slug: 'קורס-מכירות', title: 'הכשרת אנשי מכירות', desc: 'שיטות מוכחות להגדלת אחוזי הסגירה והכנסות העסק.', icon: '🤝' },
  { slug: 'בניית-אתרים', title: 'בניית אתרים', desc: 'אתרי תוכן ותדמית מהירים שממירים גולשים ללקוחות.', icon: '💻' },
  { slug: 'סוכני-ai', title: 'סוכני AI', desc: 'רתימת בינה מלאכותית לייעול וצמיחה של העסק.', icon: '🤖' },
];

// 8 most relevant industry pages (featured on the homepage)
const featuredSlugs = [
  'ייעוץ-עסקי-לרופאים',
  'ייעוץ-עסקי-לעורכי-דין',
  'ייעוץ-עסקי-למסעדות',
  'ייעוץ-עסקי-לקוסמטיקאיות',
  'ייעוץ-עסקי-לסטארטאפים',
  'ייעוץ-עסקי-למאמני-כושר',
  'ייעוץ-עסקי-לסוכני-ביטוח',
  'ייעוץ-עסקי-לקבלנים',
];
const featuredIndustries = featuredSlugs
  .map((s) => industries.find((i) => i.slug === s))
  .filter(Boolean) as { slug: string; label: string }[];

const stats = [
  { num: '12+', label: 'שנות ניסיון' },
  { num: '300+', label: 'עסקים ליווינו' },
  { num: '21', label: 'תחומי התמחות' },
  { num: '1:1', label: 'ליווי אישי' },
];

const jsonLd = buildJsonLd(home);
---
<BaseLayout
  title={home.title}
  description={home.meta_description}
  canonical="https://elad-digital.co.il/"
  ogImage="/assets/img/og-default.png"
  jsonLd={jsonLd}
  bodyClass="home"
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-deco" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-text">
        <span class="hero-name">אלעד שורתי</span>
        <h1>ייעוץ עסקי ודיגיטלי לעסקים ולחברות עם אלעד שורתי</h1>
        <p class="hero-sub">כולל ייעוץ דיגיטל וליווי עסקי - אסטרטגיה, שיווק וצמיחה תחת קורת גג אחת.</p>
        <div class="hero-actions">
          <a href="/צרו-קשר/" class="btn btn-primary btn-lg">לשיחת ייעוץ חינם</a>
          <a href={site.whatsapp} target="_blank" rel="noopener" class="btn btn-wa btn-lg">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 00-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1012 2zm4.4 12c-.2.6-1.2 1.1-1.7 1.1s-1.2.2-3.7-.9-3.9-3.6-4-3.8-1-1.3-1-2.5.6-1.7.8-1.9.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2.1.4 0 .5l-.3.5-.4.4c-.2.1-.3.3-.1.5a8 8 0 003.6 3c.3.1.4.1.6-.1l.7-.9c.2-.2.3-.2.6-.1l1.8.9c.3.1.4.2.5.3s.1.7-.1 1.2z"/></svg>
            WhatsApp
          </a>
        </div>
        <ul class="hero-trust">
          <li>✓ ליווי אישי וצמוד</li>
          <li>✓ ניסיון מוכח</li>
          <li>✓ תוצאות מדידות</li>
        </ul>
      </div>
      <div class="hero-photo">
        <img src="/assets/img/elad-cutout.webp" alt="אלעד שורתי - יועץ עסקי ומומחה שיווק דיגיטלי" width="1078" height="1241" fetchpriority="high" />
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="container stats-grid">
      {stats.map((s) => (
        <div class="stat"><span class="stat-num">{s.num}</span><span class="stat-label">{s.label}</span></div>
      ))}
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section">
    <div class="container">
      <div class="section-head text-center">
        <span class="eyebrow">השירותים שלי</span>
        <h2>כל מה שהעסק שלכם צריך כדי לצמוח</h2>
        <p class="muted">מאסטרטגיה ועד ביצוע - ליווי מקצועי בכל שלב בדרך.</p>
      </div>
      <div class="grid grid-3 services-grid">
        {services.map((s) => (
          <a href={`/${s.slug}/`} class="service-card card">
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
            <span class="service-link">קראו עוד ←</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUE / WHY ME -->
  <section class="section section-soft">
    <div class="container why-grid">
      <div>
        <span class="eyebrow">למה דווקא איתי</span>
        <h2>השילוב הייחודי של מומחיות עסקית וניסיון בשיווק דיגיטלי</h2>
        <p>אני מאמין שכל עסק, קטן או גדול, יכול להצליח בעולם הדיגיטל הסופר־תחרותי - עם הגישה הנכונה, אסטרטגיה חכמה וליווי אישי.</p>
        <ul class="check-list">
          <li>אסטרטגיית שיווק מותאמת אישית שמביאה לקוחות חדשים ומגדילה מכירות</li>
          <li>ניהול קמפיינים יעילים ברשתות החברתיות, במנועי החיפוש ובפלטפורמות נוספות</li>
          <li>יצירת תוכן שיווקי מושך שמייצר עניין אמיתי בעסק שלכם</li>
          <li>ניתוח נתונים ואופטימיזציה מתמדת - החלטות לפי מספרים, לא תחושות</li>
        </ul>
        <a href="/אודות/" class="btn btn-primary">קצת עליי ←</a>
      </div>
      <div class="why-media">
        <img src="/assets/img/digital-marketing-with-icons-business-people-1024x797.jpg" alt="ייעוץ ושיווק דיגיטלי לעסקים" width="520" height="405" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="section">
    <div class="container">
      <div class="section-head text-center">
        <span class="eyebrow">ייעוץ עסקי לפי תחום</span>
        <h2>ליווי שמכיר את עולם התוכן שלכם</h2>
        <p class="muted">לכל תחום אתגרים משלו - בחרו את התחום שלכם וגלו איך אפשר לצמוח בו.</p>
      </div>
      <div class="grid grid-4 industries-grid">
        {featuredIndustries.map((i) => (
          <a href={`/${i.slug}/`} class="industry-card">
            <span class="industry-label">{i.label}</span>
            <span class="industry-arrow" aria-hidden="true">←</span>
          </a>
        ))}
      </div>
      <div class="text-center" style="margin-top:2rem">
        <a href="/ייעוץ-עסקי-לרופאים/" class="btn btn-navy btn-lg">לכל תחומי הייעוץ</a>
      </div>
    </div>
  </section>

  <!-- BLOG -->
  <section class="section section-soft">
    <div class="container">
      <div class="section-head text-center">
        <span class="eyebrow">הבלוג העסקי</span>
        <h2>טיפים, ידע וכלים מעשיים</h2>
      </div>
      <BlogList />
      <div class="text-center" style="margin-top:2rem">
        <a href="/info-articles/" class="btn btn-ghost btn-lg">לכל המאמרים</a>
      </div>
    </div>
  </section>

  <div class="container"><CtaBand title="זה הזמן למנף את העסק שלכם" /></div>
</BaseLayout>

<style>
  .hero { position: relative; overflow: hidden;
    background: linear-gradient(155deg, #ffffff 0%, #eef2fb 55%, #e6ebf7 100%); }
  .hero-deco { position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background-image:
      radial-gradient(55% 70% at 80% 18%, rgba(64,84,178,.10), transparent 70%),
      radial-gradient(50% 60% at 12% 85%, rgba(255,136,36,.07), transparent 70%),
      repeating-linear-gradient(135deg, rgba(28,33,129,.035) 0 1px, transparent 1px 26px);
  }
  .hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.05fr .95fr;
    align-items: end; gap: 2rem; min-height: clamp(460px, 72vh, 640px); }
  .hero-text { align-self: center; padding-block: 2.5rem; }
  .hero-name { display: inline-block; font-size: 1.05rem; font-weight: 800; color: var(--cta); letter-spacing: .04em; margin-bottom: .5rem; }
  .hero-text h1 { color: var(--ink); font-size: clamp(2rem,1.2rem+3.2vw,3.45rem); line-height: 1.16; }
  .hero-sub { font-size: clamp(1.05rem,1rem+.5vw,1.3rem); color: var(--slate-700); margin-bottom: 1.8rem; max-width: 46ch; }
  .hero-actions { display: flex; gap: .8rem; flex-wrap: wrap; margin-bottom: 1.4rem; align-items: center; }
  .btn-wa { background: #25d366; color: #fff; box-shadow: 0 8px 20px rgba(37,211,102,.3); }
  .btn-wa:hover { background: #1ebe5b; color: #fff; transform: translateY(-2px); }
  .hero-trust { display: flex; gap: 1.3rem; list-style: none; padding: 0; margin: 0; flex-wrap: wrap; font-weight: 600; color: var(--slate-700); font-size: .95rem; }
  .hero-trust li { margin: 0; }
  .hero-photo { align-self: end; justify-self: center; position: relative; }
  .hero-photo::after { content: ''; position: absolute; inset-block-end: 0; inset-inline: 5%; height: 36px;
    background: radial-gradient(50% 100% at 50% 100%, rgba(20,26,94,.18), transparent 70%); z-index: -1; }
  .hero-photo img { max-height: clamp(420px, 66vh, 600px); width: auto; display: block;
    filter: drop-shadow(0 22px 36px rgba(20,26,94,.20)); }
  @media (max-width: 880px) {
    .hero-grid { grid-template-columns: 1fr; text-align: center; gap: 0; min-height: 0; padding-top: 1.5rem; }
    .hero-text { align-self: auto; padding-block: 1.5rem 1rem; }
    .hero-sub { margin-inline: auto; }
    .hero-actions, .hero-trust { justify-content: center; }
    .hero-photo img { max-height: 360px; margin-inline: auto; }
  }

  .stats { background: var(--ink); }
  .stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1rem; padding-block: 2.2rem; }
  .stat { text-align: center; color: #fff; }
  .stat-num { display: block; font-size: clamp(1.8rem,1.2rem+2vw,2.6rem); font-weight: 800; color: var(--green-400); line-height: 1; }
  .stat-label { font-size: .9rem; color: #aeb8c0; }
  @media (max-width: 560px) { .stats-grid { grid-template-columns: repeat(2,1fr); gap: 1.5rem; } }

  .section-head { max-width: 640px; margin: 0 auto 2.5rem; }
  .services-grid { margin-top: 1rem; }
  .service-card { display: flex; flex-direction: column; text-align: start; }
  .service-icon { font-size: 2.2rem; margin-bottom: .6rem; }
  .service-card h3 { margin-bottom: .4rem; }
  .service-card p { color: var(--text-muted); flex: 1; font-size: .96rem; }
  .service-link { color: var(--green-700); font-weight: 700; font-size: .92rem; margin-top: .6rem; }

  .why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  @media (max-width: 880px) { .why-grid { grid-template-columns: 1fr; } }
  .check-list { list-style: none; padding: 0; margin: 1.4rem 0; }
  .check-list li { position: relative; padding-inline-start: 2rem; margin-bottom: .9rem; }
  .check-list li::before { content: '✓'; position: absolute; inset-inline-start: 0; top: 0; width: 1.4rem; height: 1.4rem; background: var(--green-500); color: #fff; border-radius: 50%; display: grid; place-items: center; font-size: .8rem; font-weight: 700; }
  .why-media img { border-radius: 20px; box-shadow: var(--shadow); }

  .industries-grid { margin-top: 1rem; }
  .industry-card {
    display: flex; align-items: center; justify-content: space-between; gap: .5rem;
    background: #fff; border: 1px solid var(--border); border-radius: var(--radius-sm);
    padding: 1.15rem 1.3rem; font-weight: 700; color: var(--ink); font-size: 1.02rem;
    box-shadow: var(--shadow-sm); transition: all var(--transition);
  }
  .industry-card:hover { background: var(--green-600); color: #fff; border-color: var(--green-600); transform: translateY(-3px); box-shadow: 0 10px 24px rgba(28,33,129,.25); }
  .industry-arrow { color: var(--cta); font-size: 1.2rem; transition: transform var(--transition); }
  .industry-card:hover .industry-arrow { color: #fff; transform: translateX(-4px); }
</style>
