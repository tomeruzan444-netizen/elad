---
import { site, nav } from '../data/site';
const path = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? path === '/' : path.startsWith(href);
---
<header class="site-header" id="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={site.name}>
      <img src={site.logoName} alt={`${site.name} — ייעוץ ופיתוח עסקי`} width="104" height="72" />
    </a>

    <nav class="main-nav" aria-label="תפריט ראשי">
      <ul class="nav-list">
        {nav.map((item) => (
          <li class={`nav-item ${item.columns || item.mega ? 'has-dropdown' : ''}`}>
            <a
              href={item.href}
              class={`nav-link ${item.cta ? 'nav-cta' : ''} ${isActive(item.href) ? 'is-active' : ''}`}
            >
              {item.label}
              {(item.columns || item.mega) && (
                <svg class="caret" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 4l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
              )}
            </a>

            {item.columns && (
              <div class="dropdown dropdown-cols">
                <div class="dropdown-grid">
                  {item.columns.map((col) => (
                    <div class="dropdown-col">
                      <span class="dropdown-title">{col.title}</span>
                      <ul>
                        {col.links.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
                      </ul>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {item.mega && (
              <div class="dropdown dropdown-mega">
                <ul class="mega-grid">
                  {item.mega.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
                </ul>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <a href={`tel:${site.phoneRaw}`} class="header-phone" aria-label="התקשרו אלינו">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6.6 10.8a15 15 0 006.6 6.6l2.2-2.2a1 1 0 011-.24 11 11 0 003.5.56 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11 11 0 00.56 3.5 1 1 0 01-.24 1l-2.2 2.3z" fill="currentColor"/></svg>
        <span>{site.phone}</span>
      </a>
      <button class="nav-toggle" aria-label="פתיחת תפריט" aria-expanded="false" aria-controls="mobile-nav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-nav" id="mobile-nav" hidden>
    <ul>
      {nav.map((item) => (
        <li>
          <a href={item.href} class={item.cta ? 'm-cta' : ''}>{item.label}</a>
          {item.columns && (
            <ul class="m-sub">
              {item.columns.flatMap((c) => c.links).map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
            </ul>
          )}
          {item.mega && (
            <ul class="m-sub">
              {item.mega.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
            </ul>
          )}
        </li>
      ))}
    </ul>
    <a href={site.whatsapp} class="btn btn-primary" style="margin-top:1rem;width:100%;justify-content:center">דברו איתי בוואטסאפ</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 100;
    background: var(--green-600); /* brand navy */
    border-bottom: 1px solid rgba(255,255,255,.08);
    transition: box-shadow var(--transition), background var(--transition);
  }
  .site-header.scrolled { box-shadow: 0 4px 24px rgba(20,26,94,.25); background: rgba(28,33,129,.96); backdrop-filter: saturate(180%) blur(10px); }
  .header-inner { display: flex; align-items: center; gap: 1.5rem; height: 96px; }
  .brand { flex-shrink: 0; }
  .brand img { height: 74px; width: auto; }
  @media (max-width: 1080px) { .brand img { height: 56px; } .header-inner { height: 76px; } }

  .main-nav { margin-inline-start: auto; }
  .nav-list { display: flex; align-items: center; gap: .15rem; list-style: none; margin: 0; padding: 0; }
  .nav-item { position: relative; }
  .nav-link {
    display: inline-flex; align-items: center; gap: .3rem;
    padding: .55rem .8rem; border-radius: 10px; font-weight: 600; color: rgba(255,255,255,.92);
    font-size: .98rem; white-space: nowrap;
  }
  .nav-link:hover, .nav-link.is-active { background: rgba(255,255,255,.12); color: #fff; }
  .caret { transition: transform var(--transition); opacity: .7; }
  .has-dropdown:hover .caret { transform: rotate(180deg); }
  .nav-cta {
    background: linear-gradient(135deg, var(--cta), var(--cta-600));
    color: #fff !important; box-shadow: 0 6px 16px rgba(255,136,36,.35);
  }
  .nav-cta:hover { color: #fff !important; transform: translateY(-1px); }

  .dropdown {
    position: absolute; top: calc(100% + 8px); inset-inline-end: 0;
    background: #fff; border: 1px solid var(--border); border-radius: 16px;
    box-shadow: var(--shadow-lg); padding: 1.25rem;
    opacity: 0; visibility: hidden; transform: translateY(8px);
    transition: all var(--transition); z-index: 50;
  }
  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
  .dropdown-cols { width: 620px; }
  .dropdown-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .dropdown-title { display: block; font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--green-600); margin-bottom: .6rem; }
  .dropdown-col ul { list-style: none; margin: 0; padding: 0; }
  .dropdown-col li { margin: 0; }
  .dropdown-col a, .mega-grid a { display: block; padding: .4rem .5rem; border-radius: 8px; font-size: .92rem; color: var(--slate-700); }
  .dropdown-col a:hover, .mega-grid a:hover { background: var(--green-50); color: var(--green-700); }
  .dropdown-mega { width: 560px; }
  .mega-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: .15rem; list-style: none; margin: 0; padding: 0; }

  .header-actions { display: flex; align-items: center; gap: .75rem; }
  .header-phone { display: inline-flex; align-items: center; gap: .4rem; font-weight: 700; color: #fff; font-size: .95rem; }
  .header-phone:hover { color: var(--cta); }

  .nav-toggle { display: none; flex-direction: column; gap: 5px; width: 44px; height: 44px; border: 1px solid rgba(255,255,255,.25); border-radius: 10px; background: rgba(255,255,255,.08); cursor: pointer; align-items: center; justify-content: center; }
  .nav-toggle span { display: block; width: 22px; height: 2px; background: #fff; border-radius: 2px; transition: all var(--transition); }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-nav { display: none; padding: 1rem 1.25rem 2rem; background: var(--green-700); border-top: 1px solid rgba(255,255,255,.1); max-height: calc(100vh - 76px); overflow-y: auto; }
  .mobile-nav > ul { list-style: none; margin: 0; padding: 0; }
  .mobile-nav > ul > li > a { display: block; padding: .75rem .5rem; font-weight: 700; font-size: 1.05rem; color: #fff; border-bottom: 1px solid rgba(255,255,255,.1); }
  .m-cta { color: var(--cta) !important; }
  .m-sub { list-style: none; margin: 0 0 .5rem; padding: 0 1rem; }
  .m-sub a { display: block; padding: .45rem .5rem; color: rgba(255,255,255,.7); font-size: .95rem; }

  @media (max-width: 1080px) {
    .main-nav, .header-phone { display: none; }
    .nav-toggle { display: flex; }
    .header-inner { gap: .75rem; }
    .main-nav { margin-inline-start: 0; }
    body.nav-open .mobile-nav { display: block; }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const toggle = header?.querySelector('.nav-toggle') as HTMLButtonElement | null;
  const drawer = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = document.body.classList.toggle('nav-open');
    toggle.setAttribute('aria-expanded', String(open));
    if (drawer) drawer.hidden = !open;
  });
  const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
