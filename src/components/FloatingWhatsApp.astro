---
import { site } from '../data/site';
const href = `${site.whatsapp}?text=${encodeURIComponent(site.whatsappText)}`;
---
<a class="fab-whatsapp" href={href} target="_blank" rel="noopener" aria-label="שליחת הודעה בוואטסאפ">
  <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12 2a10 10 0 00-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1012 2zm0 18a8 8 0 01-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1112 20zm4.4-6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8 1-.3.2-.5.1a6.5 6.5 0 01-1.9-1.2 7.2 7.2 0 01-1.3-1.7c-.1-.2 0-.4.1-.5l.4-.4.2-.4v-.4l-.7-1.8c-.2-.5-.4-.4-.5-.4h-.5a1 1 0 00-.7.3 3 3 0 00-1 2.2c0 1.3.9 2.6 1.1 2.8s1.9 2.9 4.6 4a5.3 5.3 0 002.6.5 2.2 2.2 0 001.5-1 1.8 1.8 0 00.1-1c0-.2-.2-.3-.5-.4z"/>
  </svg>
</a>

<style>
  .fab-whatsapp {
    position: fixed; inset-block-end: 22px; inset-inline-start: 22px; z-index: 90;
    width: 58px; height: 58px; border-radius: 50%;
    background: #25d366; color: #fff;
    display: grid; place-items: center;
    box-shadow: 0 8px 24px rgba(37, 211, 102, .45);
    transition: transform var(--transition);
    animation: pulse 2.4s infinite;
  }
  .fab-whatsapp:hover { transform: scale(1.08); color: #fff; }
  @keyframes pulse {
    0% { box-shadow: 0 8px 24px rgba(37,211,102,.45), 0 0 0 0 rgba(37,211,102,.4); }
    70% { box-shadow: 0 8px 24px rgba(37,211,102,.45), 0 0 0 16px rgba(37,211,102,0); }
    100% { box-shadow: 0 8px 24px rgba(37,211,102,.45), 0 0 0 0 rgba(37,211,102,0); }
  }
</style>
