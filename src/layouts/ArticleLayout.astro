---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import ContentRenderer from '../components/ContentRenderer.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';
import type { Doc } from '../data/site';
import { label } from '../data/site';
import { buildJsonLd } from '../lib/content';

export interface Props { doc: Doc; }
const { doc } = Astro.props;

const cleanTitle = label(doc.slug) !== doc.slug ? label(doc.slug) : (doc.h1?.[0] || doc.title.split('|')[0].trim());
const h1 = doc.h1?.[0] || cleanTitle;
const faqs = doc.faqs || [];
const bodyBlocks = doc.blocks;
const jsonLd = buildJsonLd(doc);

const variant = (doc.group === 'utility' ? 'service' : doc.group) as
  'service' | 'industry' | 'post' | 'blog-index';

const eyebrowMap: Record<string, string> = {
  service: 'שירותי ייעוץ',
  industry: 'ייעוץ עסקי לפי תחום',
  post: 'הבלוג העסקי',
  'blog-index': 'מאמרים',
  utility: '',
};
const eyebrow = eyebrowMap[doc.group] ?? '';
const withSidebar = ['service', 'industry', 'post', 'blog-index'].includes(doc.group);
---
<BaseLayout
  title={doc.title}
  description={doc.meta_description}
  canonical={`https://elad-digital.co.il/${doc.slug}/`}
  ogTitle={doc.og_title}
  ogDescription={doc.og_description}
  ogImage="/assets/img/og-default.png"
  ogType={doc.type === 'post' ? 'article' : 'website'}
  robots={doc.robots}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="פירורי לחם">
        <a href="/">דף הבית</a>
        <span aria-hidden="true">›</span>
        <span>{cleanTitle}</span>
      </nav>
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h1>{h1}</h1>
      {doc.meta_description && <p class="lead">{doc.meta_description}</p>}
      <div class="hero-actions">
        <a href="/צרו-קשר/" class="btn btn-primary btn-lg">לשיחת ייעוץ חינם</a>
        <a href="#main-content" class="btn btn-ghost">קראו עוד ↓</a>
      </div>
    </div>
  </section>

  <div class="container">
    <div class={withSidebar ? 'layout-2col' : 'layout-1col'} id="main-content">
      <article class="article-body">
        <ContentRenderer blocks={bodyBlocks} />
        <Faq faqs={faqs} />
      </article>
      {withSidebar && <Sidebar variant={variant} currentSlug={doc.slug} />}
    </div>

    <CtaBand />
  </div>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(180deg, var(--green-50), #fff);
    padding-block: clamp(2rem, 1rem + 4vw, 3.5rem) clamp(1.5rem, 1rem + 2vw, 2.5rem);
    border-bottom: 1px solid var(--border);
  }
  .breadcrumb { font-size: .88rem; color: var(--text-muted); margin-bottom: 1rem; display: flex; gap: .5rem; align-items: center; }
  .breadcrumb a { color: var(--green-700); }
  .page-hero h1 { max-width: 20ch; }
  .page-hero .lead { max-width: 60ch; margin-bottom: 1.5rem; }
  .hero-actions { display: flex; gap: .8rem; flex-wrap: wrap; }

  .layout-2col { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: clamp(1.5rem, 1rem + 2vw, 3rem); padding-block: 3rem; align-items: start; }
  .layout-1col { max-width: 820px; margin-inline: auto; padding-block: 3rem; }
  .article-body { min-width: 0; }
  @media (max-width: 980px) {
    .layout-2col { grid-template-columns: 1fr; }
    .layout-2col :global(.sidebar) { position: static; }
  }
</style>
